// Illuminate Life Gala - Additional Schema
// Add these models to your main schema.prisma file

model Booking {
  id                   String         @id @default(cuid())
  type                 BookingType
  status               BookingStatus  @default(PENDING)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  
  // Customer Information
  customerName         String
  customerEmail        String
  customerPhone        String
  companyName          String?
  
  // Booking Details
  ticketTier           String?
  ticketName           String?
  sponsorTier          String?
  brandingType         String?
  quantity             Int
  pricePerUnit         Decimal        @db.Decimal(10, 2)
  totalAmount          Decimal        @db.Decimal(10, 2)
  
  // Seat Assignment
  seatNumbers          String[]
  tableNumber          String?
  sectionName          String?
  
  // Additional Information
  specialRequests      String?        @db.Text
  dietaryRestrictions  String?        @db.Text
  tablePreferences     String?        @db.Text
  message              String?        @db.Text
  
  // Admin Management
  adminNotes           String?        @db.Text
  followUpDate         DateTime?
  assignedTo           String?
  
  // Relations
  sponsor              Sponsor?
  branding             BrandingOpportunity?
  seats                Seat[]
  activityLogs         ActivityLog[]
  
  @@index([type])
  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
  @@map("bookings")
}

model Sponsor {
  id                   String         @id @default(cuid())
  bookingId            String         @unique
  tier                 String
  companyName          String
  contactName          String
  contactEmail         String
  contactPhone         String
  logoUrl              String?
  websiteUrl           String?
  description          String?        @db.Text
  status               SponsorStatus  @default(INQUIRY)
  displayOrder         Int            @default(0)
  isActive             Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  
  booking              Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@index([displayOrder])
  @@map("sponsors")
}

model BrandingOpportunity {
  id                   String         @id @default(cuid())
  bookingId            String         @unique
  type                 String
  companyName          String
  contactName          String
  contactEmail         String
  contactPhone         String
  specifications       Json?
  artworkUrl           String?
  status               BrandingStatus @default(INQUIRY)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  
  booking              Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@map("branding_opportunities")
}

model Seat {
  id                   String         @id @default(cuid())
  seatNumber           String         @unique
  tableNumber          String?
  sectionName          String
  seatType             SeatType
  isAvailable          Boolean        @default(true)
  bookingId            String?
  reservedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  
  booking              Booking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  
  @@index([sectionName])
  @@index([isAvailable])
  @@index([bookingId])
  @@map("seats")
}

model AdminUser {
  id                   String         @id @default(cuid())
  email                String         @unique
  passwordHash         String
  role                 AdminRole      @default(ADMIN)
  name                 String
  isActive             Boolean        @default(true)
  lastLogin            DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  
  activityLogs         ActivityLog[]
  
  @@map("admin_users")
}

model ActivityLog {
  id                   String         @id @default(cuid())
  timestamp            DateTime       @default(now())
  action               String
  entityType           EntityType
  entityId             String
  userId               String?
  details              Json?
  ipAddress            String?
  
  user                 AdminUser?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  booking              Booking?       @relation(fields: [entityId], references: [id], onDelete: Cascade)
  
  @@index([entityType, entityId])
  @@index([timestamp])
  @@index([userId])
  @@map("activity_logs")
}

// Enums
enum BookingType {
  TICKET
  SPONSOR
  BRANDING
}

enum BookingStatus {
  PENDING
  CONTACTED
  CONFIRMED
  CANCELLED
}

enum SponsorStatus {
  INQUIRY
  NEGOTIATING
  CONFIRMED
  ACTIVE
  INACTIVE
}

enum BrandingStatus {
  INQUIRY
  PENDING_APPROVAL
  APPROVED
  ACTIVE
}

enum SeatType {
  INDIVIDUAL
  TABLE
  VIP
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum EntityType {
  BOOKING
  SPONSOR
  BRANDING
  ADMIN
  SEAT
}
