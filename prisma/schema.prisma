// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id                   String   @id @default(cuid())
  eventName            String
  description          String?
  eventDate            DateTime
  eventStartTime       String   // Format: "19:00"
  eventEndTime         String   // Format: "23:00"
  venueName            String
  venueAddress         String
  venueCity            String
  venueState           String
  venueZipCode         String
  venueLatitude        Float?
  venueLongitude       Float?
  capacity             Int
  currentRegistrations Int      @default(0)
  waitlistEnabled      Boolean  @default(true)
  registrationOpen     Boolean  @default(true)
  dressCode            String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  invites              Invite[]
  attendees            Attendee[]
  
  @@map("events")
}

model Invite {
  id                String      @id @default(cuid())
  email             String
  token             String      @unique
  isUsed            Boolean     @default(false)
  expiresAt         DateTime
  eventId           String
  createdAt         DateTime    @default(now())
  lastReminderSent  DateTime?
  reminderCount     Int         @default(0)
  
  event             Event       @relation(fields: [eventId], references: [id])
  attendee          Attendee?
  
  @@map("invites")
}

model Attendee {
  id               String         @id @default(cuid())
  name             String
  company          String
  title            String
  email            String
  status           AttendeeStatus @default(CONFIRMED)
  qrCode           String         @unique
  registrationId   String         @unique // Format: "REG-12345678"
  inviteId         String         @unique
  eventId          String
  checkedInAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  
  invite           Invite         @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  event            Event          @relation(fields: [eventId], references: [id])
  plusOne          PlusOne?
  
  @@map("attendees")
}

model PlusOne {
  id             String   @id @default(cuid())
  name           String
  company        String
  title          String
  email          String
  qrCode         String   @unique
  registrationId String   @unique
  attendeeId     String   @unique
  checkedInAt    DateTime?
  createdAt      DateTime @default(now())
  
  attendee       Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  
  @@map("plus_ones")
}

enum AttendeeStatus {
  CONFIRMED
  WAITLISTED
  CANCELLED
}


// Illuminate Life Gala - Additional Models

model Booking {
  id                   String         @id
  type                 BookingType
  status               BookingStatus  @default(PENDING)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  
  // Customer Information
  customerName         String
  customerEmail        String
  customerPhone        String
  companyName          String?
  
  // Booking Details
  ticketTier           String?
  ticketName           String?
  sponsorTier          String?
  brandingType         String?
  quantity             Int
  pricePerUnit         Decimal        @db.Decimal(10, 2)
  totalAmount          Decimal        @db.Decimal(10, 2)
  
  // Seat Assignment
  seatNumbers          String[]
  tableNumber          String?
  seatAssignments      Json?          // [{ name: string, seatNumber: string }]
  
  // Additional Information
  specialRequests      String?        @db.Text
  dietaryRestrictions  String?        @db.Text
  tablePreferences     String?        @db.Text
  message              String?        @db.Text
  
  // Admin Management
  adminNotes           String?        @db.Text
  followUpDate         DateTime?
  assignedTo           String?
  
  // Relations
  sponsor              Sponsor?
  branding             BrandingOpportunity?
  seats                Seat[]
  plusOnes             IlluminatePlusOne[]
  
  @@index([type])
  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
  @@map("bookings")
}

model IlluminatePlusOne {
  id                   String         @id @default(cuid())
  bookingId            String
  name                 String
  email                String
  phone                String?
  qrCode               String         @unique
  seatNumber           String?
  dietaryRestrictions  String?        @db.Text
  specialRequests      String?        @db.Text
  checkedIn            Boolean        @default(false)
  checkedInAt          DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  
  booking              Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@index([bookingId])
  @@index([email])
  @@index([qrCode])
  @@map("illuminate_plus_ones")
}

model Sponsor {
  id                   String         @id @default(cuid())
  bookingId            String         @unique
  tier                 String
  companyName          String
  contactName          String
  contactEmail         String
  contactPhone         String
  logoUrl              String?
  websiteUrl           String?
  description          String?        @db.Text
  status               SponsorStatus  @default(INQUIRY)
  displayOrder         Int            @default(0)
  isActive             Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  
  booking              Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@index([displayOrder])
  @@map("sponsors")
}

model BrandingOpportunity {
  id                   String         @id @default(cuid())
  bookingId            String         @unique
  type                 String
  companyName          String
  contactName          String
  contactEmail         String
  contactPhone         String
  specifications       Json?
  artworkUrl           String?
  status               BrandingStatus @default(INQUIRY)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  
  booking              Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@map("branding_opportunities")
}

model Seat {
  id                   String         @id @default(cuid())
  seatNumber           String         @unique
  tableNumber          String?
  seatType             SeatType
  isAvailable          Boolean        @default(true)
  bookingId            String?
  plusOneId            String?        // Reference to Plus One if seat is for a Plus One
  reservedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  
  booking              Booking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  
  @@index([isAvailable])
  @@index([bookingId])
  @@index([plusOneId])
  @@map("seats")
}

model AdminUser {
  id                   String         @id @default(cuid())
  email                String         @unique
  passwordHash         String
  role                 AdminRole      @default(ADMIN)
  name                 String
  isActive             Boolean        @default(true)
  lastLogin            DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  
  activityLogs         ActivityLog[]
  
  @@map("admin_users")
}

model ActivityLog {
  id                   String         @id @default(cuid())
  timestamp            DateTime       @default(now())
  action               String
  entityType           EntityType
  entityId             String
  userId               String?
  details              Json?
  ipAddress            String?
  
  user                 AdminUser?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([entityType, entityId])
  @@index([timestamp])
  @@index([userId])
  @@map("activity_logs")
}

// Illuminate Enums
enum BookingType {
  TICKET
  SPONSOR
  BRANDING
}

enum BookingStatus {
  PENDING
  CONTACTED
  CONFIRMED
  CANCELLED
}

enum SponsorStatus {
  INQUIRY
  NEGOTIATING
  CONFIRMED
  ACTIVE
  INACTIVE
}

enum BrandingStatus {
  INQUIRY
  PENDING_APPROVAL
  APPROVED
  ACTIVE
}

enum SeatType {
  INDIVIDUAL
  TABLE
  VIP
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum EntityType {
  BOOKING
  SPONSOR
  BRANDING
  ADMIN
  SEAT
}
