# Database
DATABASE_URL="postgresql://username:password@localhost:5432/event_rsvp?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Admin Credentials (for demo purposes - in production, use a proper user management system)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# Email Service (Resend API)
# Get your API key from: https://resend.com/api-keys
# You must verify your domain first: https://resend.com/domains
RESEND_API_KEY="re_xxxxxxxxx"
# The email address that will appear in the "From" field (must be from your verified domain)
# Format: "Name <email@yourdomain.com>" or just "email@yourdomain.com"
FROM_EMAIL="Events <noreply@yourdomain.com>"

# Automated Reminder Emails
# Enable/disable automated reminder emails for pending invitations
ENABLE_AUTO_REMINDERS="false"
# How many days between reminder emails (default: 7 days)
REMINDER_INTERVAL_DAYS="7"
# How often to check for pending reminders in hours (default: 24 hours)
REMINDER_CHECK_INTERVAL_HOURS="24"

# Frontend URLs
FRONTEND_URL="https://levyeromomedia.com"
ADMIN_URL="https://admin.levyeromomedia.com"

# Email Images - Self-hosted on our server
# Production: https://api.levyeromomedia.com/static/email-images/
EMAIL_HERO_IMAGE_URL="https://api.levyeromomedia.com/static/email-images/mask-group.png"
EMAIL_LOGO_URL="https://api.levyeromomedia.com/static/email-images/lemm.png"
EMAIL_CALENDAR_ICON_URL="https://api.levyeromomedia.com/static/email-images/calendar.png"
EMAIL_CLOCK_ICON_URL="https://api.levyeromomedia.com/static/email-images/clock.png"
EMAIL_LOCATION_ICON_URL="https://api.levyeromomedia.com/static/email-images/location.png"
EMAIL_BOW_ICON_URL="https://api.levyeromomedia.com/static/email-images/bow.png"
# Server
PORT=3001
NODE_ENV="development"

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Google Sheets Integration (Optional)
# See GOOGLE_SHEETS_ALTERNATIVE_SOLUTIONS.md for setup instructions
#
# RECOMMENDED: Use Google Apps Script webhook (easiest, no auth needed!)
# 1. Open your Google Sheet
# 2. Go to Extensions > Apps Script
# 3. Deploy as Web App (see guide for code)
# 4. Paste the webhook URL here:
GOOGLE_SHEETS_WEBHOOK_URL=""
#
# ALTERNATIVE: Use Service Account (if your org allows it)
# Get your Google Sheet ID from the URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEET_ID=""
# Option 1: Service Account JSON as string (recommended for production)
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
# Option 2: Service Account JSON file path (easier for development)
GOOGLE_SERVICE_ACCOUNT_PATH="./google-credentials.json"
